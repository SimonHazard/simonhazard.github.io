---
import Base from "@/layouts/Base.astro";
import ArticleCard from "@/components/custom/ArticleCard.astro";
import ProjectCard from "@/components/custom/ProjectCard.astro";
import Barcode from "@/components/custom/Barcode.astro";
import { getCollection } from "astro:content";
import { ArrowRight } from "@lucide/astro";
import { t } from "@/i18n/utils";
import { sortByDate } from "@/lib/utils";

const [allArticles, featuredProjects] = await Promise.all([
  getCollection("articles", ({ data }) => !data.draft),
  getCollection("projects", ({ data }) => data.featured),
]);

const latestArticles = sortByDate(allArticles).slice(0, 3);
---

<Base title="Home">
  <section class="py-12 sm:py-16 md:py-24 animate-slide-up">
    <div class="flex items-center gap-3 mb-6">
      <Barcode class="hidden sm:flex" />
      <span class="label-ui text-muted-foreground">{t("home.subtitle")}</span>
    </div>

    <h1 class="font-black text-3xl sm:text-4xl md:text-6xl leading-none mb-6">
      SIMON<br />
      <span class="text-primary">HAZARD</span>
    </h1>

    <p class="text-base sm:text-lg text-muted-foreground max-w-xl mb-8">
      {t("home.description")}
    </p>

    <div class="flex flex-col sm:flex-row flex-wrap gap-3">
      <a
        href="/articles"
        class="inline-flex items-center justify-center font-mono text-[10px] uppercase tracking-[0.15em] font-bold bg-primary text-primary-foreground h-10 px-6 rounded-sm hover:brightness-110 transition-all duration-75"
      >
        {t("home.readArticles")}
      </a>
      <a
        href="/static/simon-hazard.pdf"
        download
        class="inline-flex items-center justify-center font-mono text-[10px] uppercase tracking-[0.15em] font-bold border border-border h-10 px-6 rounded-sm hover:bg-primary hover:text-primary-foreground transition-all duration-75"
      >
        {t("home.downloadCV")}
      </a>
    </div>
  </section>

  {featuredProjects.length > 0 && (
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-8">
        <span class="label-ui text-primary">{t("home.featuredProjects")}</span>
        <div class="flex-1 h-px bg-border opacity-30"></div>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {featuredProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            stack={project.data.stack}
            githubUrl={project.data.githubUrl}
            liveUrl={project.data.liveUrl}
          />
        ))}
      </div>
      <div class="mt-6">
        <a href="/projects" class="label-ui text-muted-foreground hover:text-primary transition-colors inline-flex items-center gap-1.5">
          {t("home.allProjects")} <ArrowRight class="size-3" />
        </a>
      </div>
    </section>
  )}

  {latestArticles.length > 0 && (
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-8">
        <span class="label-ui text-primary">{t("home.latestArticles")}</span>
        <div class="flex-1 h-px bg-border opacity-30"></div>
      </div>
      <div class="grid gap-4">
        {latestArticles.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            date={article.data.date}
            category={article.data.category}
            tags={article.data.tags}
            lang={article.data.lang}
            href={`/articles/${article.id}`}
            ai={article.data.ai}
          />
        ))}
      </div>
      <div class="mt-6">
        <a href="/articles" class="label-ui text-muted-foreground hover:text-primary transition-colors inline-flex items-center gap-1.5">
          {t("home.allArticles")} <ArrowRight class="size-3" />
        </a>
      </div>
    </section>
  )}
</Base>
