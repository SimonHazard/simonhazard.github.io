---
import { formatDate } from "@/lib/utils";
import { t } from "@/i18n/utils";

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  tags: string[];
  lang: "fr" | "en";
  href: string;
  ai: boolean;
}

const { title, description, date, category, tags, lang, href, ai } = Astro.props;
---

<a href={href} class="group block">
  <article class="relative border border-border rounded-sm p-4 sm:p-6 transition-all duration-75 [@media(hover:hover)]:hover:translate-x-0.5 [@media(hover:hover)]:hover:translate-y-0.5 bg-card">
    <div class="absolute inset-0 border border-border rounded-sm -translate-x-0.5 -translate-y-0.5 opacity-0 [@media(hover:hover)]:group-hover:opacity-100 transition-opacity duration-75 pointer-events-none" aria-hidden="true"></div>

    <div class="flex flex-wrap items-center gap-2 sm:gap-3 mb-3">
      <span class="label-ui text-primary">{category}</span>
      <span class="label-ui text-muted-foreground">{formatDate(date, lang)}</span>
      <span class="label-ui border border-input px-1.5 py-0.5 text-muted-foreground">{lang.toUpperCase()}</span>
    </div>

    <h3 class="font-black text-base sm:text-lg mb-2 [@media(hover:hover)]:group-hover:text-primary transition-colors">
      {title}
    </h3>

    <p class="text-sm text-muted-foreground mb-4 line-clamp-2">
      {description}
    </p>

    <div class="flex flex-wrap gap-1.5 sm:gap-2">
      {tags.map((tag) => (
        <span class="inline-flex items-center font-mono text-[9px] sm:text-[10px] uppercase tracking-[0.15em] border border-input px-1.5 sm:px-2 py-0.5 text-muted-foreground">
          {tag}
        </span>
      ))}
    </div>

    {ai && (
      <div class="flex items-center gap-2 mt-4">
        <span class="relative group/ai inline-flex">
          <span class="inline-flex items-center font-mono text-[9px] sm:text-[10px] uppercase tracking-[0.15em] border border-input px-1.5 sm:px-2 py-0.5 text-muted-foreground cursor-help">
            {t("articles.aiAssisted")}
          </span>
          <span class="absolute bottom-full left-0 mb-2 w-56 p-2.5 text-[10px] font-mono normal-case tracking-normal leading-relaxed bg-card border border-border text-muted-foreground opacity-0 group-hover/ai:opacity-100 transition-opacity duration-150 pointer-events-none z-20">
            {t("articles.aiAssistedDescription")}
          </span>
        </span>
      </div>
    )}
  </article>
</a>
