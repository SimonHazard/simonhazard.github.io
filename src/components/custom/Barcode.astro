---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;

const bars = [
  2, 1, 2, 1, 1, 2, 1, 2, 2, 1, 1, 2, 1, 1, 2, 1, 2, 1, 1, 2, 1, 2, 1, 1, 2, 1, 2, 1, 1, 2, 1, 2,
];
const heights = [
  20, 18, 22, 16, 24, 19, 17, 23, 21, 16, 20, 18, 22, 24, 19, 17, 23, 16, 21, 20, 18, 22, 24, 19,
  17, 23, 16, 21, 20, 18, 22, 24,
];
---

<div class:list={["flex items-center gap-0.5 opacity-30 select-none", className]} aria-hidden="true">
  {bars.map((w, i) => (
    <div
      class="bg-foreground"
      style={`width: ${w}px; height: ${heights[i]}px;`}
    />
  ))}
</div>
