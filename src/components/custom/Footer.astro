---
import Barcode from "./Barcode.astro";
import SimpleIcon from "./SimpleIcon.astro";
import { siGithub } from "simple-icons";
---

<footer class="border-t border-border mt-20 no-print">
  <div class="max-w-5xl mx-auto px-4 py-8 flex flex-col items-center gap-4">
    <Barcode />
    <div class="flex items-center gap-4">
      <a
        href="https://github.com/SimonHazard"
        target="_blank"
        rel="noopener noreferrer"
        class="label-ui inline-flex items-center gap-1.5 text-muted-foreground hover:text-primary transition-colors"
        aria-label="Simon Hazard on GitHub"
      >
        <SimpleIcon path={siGithub.path} title={siGithub.title} class="size-4" /> GitHub
      </a>
      <span class="text-muted-foreground">·</span>
      <span class="label-ui text-muted-foreground">
        {new Date().getFullYear()} Simon HAZARD
      </span>
    </div>
  </div>
</footer>
